{
    "default": {
        "formatOptions":{
            "snippetInterface": "async-await"
        },
        "paths": [
            "src/test/features/"
        ],
        "require": [
            "src/test/steps/*.ts",
            "src/hooks/hooks.ts"
        ],
        "requireModule": ["ts-node/register"],
        "format": [
            "json:test-results/cucumber_report.json",
            "html:cucumber-report.html"
        ]
    }
}